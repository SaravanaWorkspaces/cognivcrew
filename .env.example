# =============================================================================
# CognivCrew — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED
# -----------------------------------------------------------------------------

# Your Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here


# -----------------------------------------------------------------------------
# OPTIONAL — LangSmith tracing (recommended for debugging)
# -----------------------------------------------------------------------------

# Set to "true" to enable LangSmith trace collection
# LANGCHAIN_TRACING_V2=true

# Your LangSmith API key — get one at https://smith.langchain.com
# LANGCHAIN_API_KEY=your_langsmith_api_key_here

# LangSmith project name for organising runs (defaults to "default")
# LANGCHAIN_PROJECT=cognivcrew


# -----------------------------------------------------------------------------
# OPTIONAL — Pipeline behaviour overrides
# -----------------------------------------------------------------------------

# Maximum number of QA -> Engineer revision cycles before accepting output
# Default: 3
# MAX_ITERATIONS=3

# Logging verbosity: DEBUG, INFO, WARNING, ERROR
# Terminal output respects this level; the log file always captures DEBUG.
# Default: INFO
# LOG_LEVEL=INFO


# -----------------------------------------------------------------------------
# OPTIONAL — Execution mode
# -----------------------------------------------------------------------------

# How CognivCrew calls Claude:
#   api         — uses ANTHROPIC_API_KEY (default)
#   pro_native  — uses Claude Code CLI with your Claude Pro plan (no API key needed)
#                 Requires: npm install -g @anthropic-ai/claude-code  +  cognivcrew auth-pro
#   mock        — zero LLM calls; pre-canned outputs; engineer always produces hello_world.py
# Default: api
# EXECUTION_MODE=api


# -----------------------------------------------------------------------------
# OPTIONAL — Test layer
# -----------------------------------------------------------------------------

# Force mock execution mode regardless of EXECUTION_MODE above.
# When true: zero LLM calls, zero cost, engineer stage writes hello_world.py.
# Use for CI pipelines, smoke tests, and local pipeline validation.
# Default: false
# TEST_MODE=false
